{
  "name": "cekta/serialize",
  "description": "safe encode/decode object to json and back.",
  "type": "library",
  "license": "GPL-3.0-only",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require": {
    "ext-json": "*",
    "php": ">=8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "@stable",
    "squizlabs/php_codesniffer": "@stable",
    "phpstan/phpstan": "@stable",
    "infection/infection": "^0.32.6"
  },
  "scripts": {
    "test": [
      "@composer install",
      "@phpcs",
      "@phpstan",
      "@phpunit",
      "@infection"
    ],
    "phpcs": "./vendor/bin/phpcs",
    "phpstan": "./vendor/bin/phpstan analyse --memory-limit=-1",
    "phpunit": "./vendor/bin/phpunit",
    "infection": "./vendor/bin/infection --show-mutations"
  },
  "autoload": {
    "psr-4": {
      "Cekta\\Serializer\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Cekta\\Serializer\\Test\\": "tests/"
    }
  },
  "authors": [
    {
      "name": "Evgeniy Kuvshinov",
      "email": "smpl@itmywork.com"
    }
  ],
  "config": {
    "allow-plugins": {
      "infection/extension-installer": true
    }
  }
}
